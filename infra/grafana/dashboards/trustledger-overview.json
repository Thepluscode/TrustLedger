{
  "title": "TrustLedger — Operations Cockpit",
  "schemaVersion": 39,
  "tags": ["trustledger"],
  "panels": [
    {
      "id": 1, "title": "Transfers created (rate)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(trustledger_transfers_created_total[5m])" }]
    },
    {
      "id": 2, "title": "Transfers by outcome", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "trustledger_transfers_completed_total", "legendFormat": "completed" },
        { "expr": "trustledger_transfers_held_total", "legendFormat": "held" },
        { "expr": "trustledger_transfers_rejected_total", "legendFormat": "rejected" }
      ]
    },
    {
      "id": 3, "title": "p95 transfer API latency", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/v1/transfers\"}[5m])) by (le))" }]
    },
    {
      "id": 4, "title": "Backend up", "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "up{job=\"trustledger-backend\"}" }]
    }
  ]
}
